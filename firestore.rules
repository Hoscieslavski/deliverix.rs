rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - deny anything else
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write access to candidates for Express backend processing
    match /candidates/{candidateId} {
      allow read, write: if true;
    }

    // Allow read/write access to admins for backend verification
    match /admins/{adminId} {
      allow read, write: if true;
    }

    // Allow read/write access to blog posts for public display and admin updates
    match /blog_posts/{postId} {
      allow read, write: if true;
    }

    // Allow read/write access to site configs for SEO setups and logo styles
    match /site_configs/{configId} {
      allow read, write: if true;
    }
  }
}
